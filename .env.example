# ══════════════════════════════════════════════════════════════
#  .env — SonarAI v3.0 Configuration Template
#  Copy this to .env and fill in your credentials
# ══════════════════════════════════════════════════════════════

# ── GITHUB CONFIG ──────────────────────────────────────────────
# Your GitHub username
GITHUB_USERNAME=your_username_here

# GitHub Personal Access Token
# Generate at: https://github.com/settings/tokens/new
# Permissions: repo (full), read:user
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LOCAL REPO PATHS ────────────────────────────────────────────
# Base path where repos will be cloned
REPO_PATH=D:\SonarQube\SonarQube-AI-Agent

# Custom path for specific repo (optional)
# Format: REPO_PATH_<exact-repo-name>
REPO_PATH_sonarqube-ai-agent-v1=D:\SonarQube\sonarqube-ai-agent-v1

# ── LOCAL SONARQUBE ─────────────────────────────────────────────
# SonarQube server URL (local or remote)
SONAR_URL=http://localhost:9000

# SonarQube token
# Generate: Login → My Account → Security → Generate Token
SONAR_TOKEN=sqa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── DOTNET PATH ──────────────────────────────────────────────────
# .NET SDK installation path
# Check with: where dotnet
DOTNET_ROOT=C:\Program Files\dotnet\

# ── CLAUDE AI (Code Review) ─────────────────────────────────────
# Anthropic API Key
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SERVER PORT ──────────────────────────────────────────────────
PORT=3002

# ── EMAIL NOTIFICATIONS ──────────────────────────────────────────
# Gmail SMTP configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your Gmail address
SMTP_USER=your_email@gmail.com

# Gmail App Password (NOT regular password)
# Generate: Google Account → Security → 2-Step Verification → App passwords
SMTP_PASS=xxxx xxxx xxxx xxxx

# Email recipient for notifications
NOTIFY_EMAIL=your_email@gmail.com
